# Default: normalize line endings to LF in the repo, auto-detect on checkout.
* text=auto eol=lf

# Source / config — always LF (Linux-only target, scripts must stay executable)
*.py        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.service   text eol=lf
*.rules     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.urdf      text eol=lf
*.xacro     text eol=lf
*.json      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf

# Windows-only scripts (if ever added) — CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary assets — never munge line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.svg       text eol=lf
*.pdf       binary
*.ico       binary

# 3D meshes (if added later for rviz/urdf)
*.stl       binary
*.dae       binary
*.obj       binary

# ML model files
*.tflite    binary
*.onnx      binary
*.pt        binary
*.pth       binary
*.pb        binary
*.h5        binary

# Pre-packaged installers (depend/)
*.deb       binary
*.whl       binary
*.tar.gz    binary
*.tgz       binary
*.zip       binary

# ROS2 bag files
*.bag       binary
*.bag2      binary
*.db3       binary
*.mcap      binary

# Calibration data
*.bin       binary
